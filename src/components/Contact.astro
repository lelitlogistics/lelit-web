---
---

<section class="contact" id="contact">
  <div class="wrap contact__inner">
    <div class="contact__lead" data-reveal>
      <span class="eyebrow">Contact</span>
      <h2>Let's talk.</h2>
      <p>
        Drivers, fill out the form and we'll be in touch fast. For partnerships
        or anything else, email us directly at
        <a href="mailto:hiring@lelitlogistics.com">hiring@lelitlogistics.com</a>.
      </p>
      <ul class="contact__facts">
        <li><span>Station</span><strong>DOB7 — Glastonbury, CT</strong></li>
        <li><span>Email</span><strong>hiring@lelitlogistics.com</strong></li>
        <li><span>Response</span><strong>Within 48 business hours</strong></li>
      </ul>
    </div>

    <form class="form" data-reveal id="apply-form" novalidate>
      <div class="hp" aria-hidden="true">
        <label>Leave this empty if you're human
          <input type="text" name="company_website" tabindex="-1" autocomplete="off" />
        </label>
      </div>

      <div class="field">
        <label for="f-name">Full name</label>
        <input id="f-name" name="name" type="text" required autocomplete="name" />
      </div>

      <div class="field-row">
        <div class="field">
          <label for="f-phone">Phone</label>
          <input id="f-phone" name="phone" type="tel" required autocomplete="tel" />
        </div>
        <div class="field">
          <label for="f-email">Email</label>
          <input id="f-email" name="email" type="email" required autocomplete="email" />
        </div>
      </div>

      <div class="field">
        <label for="f-role">I'm interested in</label>
        <select id="f-role" name="role" required>
          <option value="">Select one…</option>
          <option>Full-Time Driver</option>
          <option>Part-Time Driver</option>
          <option>Partnership / business inquiry</option>
        </select>
      </div>

      <div class="field">
        <label for="f-msg">Anything we should know? <span>(optional)</span></label>
        <textarea id="f-msg" name="message" rows="4"></textarea>
      </div>

      <button type="submit" class="btn btn--dark form__submit">
        Send application <span class="arrow">↗</span>
      </button>

      <p class="form__consent">
        By submitting, you agree to be contacted by phone, email, or SMS about
        your application. Message and data rates may apply; reply STOP to opt
        out. See our <a href="/privacy">Privacy Policy</a>.
      </p>

      <p class="form__status" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<script>
  const ENDPOINT = 'https://hireflow-production-04a4.up.railway.app/api/apply';
  const bind = () => {
    const form = document.getElementById('apply-form');
    if (!form || form.dataset.bound) return;
    form.dataset.bound = '1';
    const status = form.querySelector('.form__status');
    const btn = form.querySelector('.form__submit');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (form.company_website && form.company_website.value) return;
      if (!form.checkValidity()) { form.reportValidity(); return; }
      const data = Object.fromEntries(new FormData(form).entries());
      delete data.company_website;
      btn.disabled = true; btn.style.opacity = '0.6';
      status.textContent = 'Sending…'; status.className = 'form__status';
      try {
        if (ENDPOINT) {
          const res = await fetch(ENDPOINT, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
          if (!res.ok) throw new Error('bad response');
        } else { await new Promise((r) => setTimeout(r, 500)); }
        form.reset();
        status.textContent = "Received. We'll get back to you within 48 business hours.";
        status.classList.add('ok');
        // Analytics: registrar la aplicación como conversión (si GA está activo)
        if (typeof window.gtag === 'function') {
          window.gtag('event', 'generate_lead', { form: 'apply', role: data.role || '' });
        }
      } catch (err) {
        status.textContent = "Couldn't send right now — email us at hiring@lelitlogistics.com.";
        status.classList.add('err');
      } finally { btn.disabled = false; btn.style.opacity = ''; }
    });
  };
  bind();
  document.addEventListener('astro:after-swap', bind);
</script>

<style>
  .contact { padding-block: clamp(5rem, 11vw, 9rem); background: var(--bg); border-top: 1px solid var(--line); }
  .contact__inner { display: grid; grid-template-columns: 5fr 6fr; gap: clamp(var(--s6), 6vw, var(--s12)); align-items: start; }
  .contact__lead h2 { margin-bottom: var(--s3); }
  .contact__lead p { font-size: 16.5px; line-height: 1.65; max-width: 400px; }
  .contact__lead a { color: var(--ink); }
  .contact__facts { list-style: none; margin-top: var(--s5); display: flex; flex-direction: column; gap: var(--s2); }
  .contact__facts li { display: flex; flex-direction: column; gap: 2px; padding: var(--s2) 0; border-top: 1px solid var(--line); }
  .contact__facts span { font-size: 12px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--gray); }
  .contact__facts strong { font-size: 15.5px; font-weight: 600; color: var(--ink); letter-spacing: -0.01em; }

  .form {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: clamp(var(--s4), 4vw, var(--s6));
    box-shadow: var(--shadow-soft);
    display: flex; flex-direction: column; gap: var(--s3);
  }
  .hp { position: absolute; left: -9999px; opacity: 0; height: 0; overflow: hidden; }
  .form label { display: flex; flex-direction: column; gap: 8px; font-size: 13.5px; font-weight: 600; color: var(--ink); }
  .form .row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--s2); }
  .form input, .form select, .form textarea {
    height: 50px; padding: 0 16px;
    border: 1px solid var(--line); border-radius: var(--r-sm);
    background: var(--bg); color: var(--ink);
    font: 500 15px/1.4 var(--font);
    transition: border-color .3s var(--ease), background .3s var(--ease), box-shadow .3s var(--ease);
    outline: none; appearance: none;
  }
  .form textarea { height: auto; padding: 14px 16px; resize: vertical; }
  .form input:focus, .form select:focus, .form textarea:focus {
    border-color: var(--accent); background: var(--white);
    box-shadow: 0 0 0 4px rgba(46,107,230,.08);
  }
  .form__submit { justify-content: center; margin-top: var(--s1); }
  .form__fine { font-size: 12.5px; color: var(--gray); line-height: 1.5; }
  .form__fine a { color: var(--ink); }
  .form__status { font-size: 14px; font-weight: 600; }
  .form__status.ok { color: #1a7f4b; }
  .form__status.err { color: #c2333b; }
  @media (max-width: 860px) { .contact__inner { grid-template-columns: 1fr; } .form .row { grid-template-columns: 1fr; } }
</style>
