---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap footer__inner">
    <div class="footer__brand">
      <img src="/logo.png" alt="" class="footer__logo" width="32" height="32" />
      <span class="footer__name">Lelit Logistics LLC</span>
      <p class="footer__tag">Amazon Delivery Service Partner · Station DOB7</p>
    </div>
    <nav class="footer__nav" aria-label="Footer">
      <a href="/#company">Company</a>
      <a href="/#operation">Operation</a>
      <a href="/#careers">Drive with us</a>
      <a href="/#contact">Contact</a>
      <a href="/privacy">Privacy Policy</a>
      <a href="mailto:hiring@lelitlogistics.com">hiring@lelitlogistics.com</a>
    </nav>
  </div>
  <div class="wrap footer__base">
    <span>© {year} Lelit Logistics LLC · Glastonbury, Connecticut</span>
    <span>Equal opportunity employer</span>
  </div>
</footer>

<style>
  .footer { background: var(--bg); border-top: 1px solid var(--line); padding-block: clamp(3rem, 6vw, 4.5rem) 1.6rem; }
  .footer__inner { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 2rem; padding-bottom: 2.5rem; border-bottom: 1px solid var(--line); }
  .footer__logo { object-fit: contain; }
  .footer__name { font-family: var(--font-display); font-size: 1.4rem; display: block; margin-top: 0.5rem; }
  .footer__tag { color: var(--fg-faint); font-size: 0.9rem; margin-top: 0.3rem; }
  .footer__nav { display: flex; flex-wrap: wrap; gap: 0.4rem 1.6rem; align-content: start; }
  .footer__nav a { color: var(--fg-soft); font-size: 0.95rem; transition: color 0.25s var(--ease); }
  .footer__nav a:hover { color: var(--orange-soft); }
  .footer__base { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; padding-top: 1.6rem; font-size: 0.82rem; color: var(--fg-faint); }
</style>
