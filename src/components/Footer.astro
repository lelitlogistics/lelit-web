---
const year = new Date().getFullYear();
---
<footer class="footer dark">
  <div class="wrap footer__cta" data-reveal>
    <h2>Ready when you are.</h2>
    <a href="#contact" class="btn btn--light">Start your application <span class="arrow">↗</span></a>
  </div>
  <div class="wrap footer__bar">
    <div class="footer__brand">
      <img src="/logo-mark.png" alt="" width="26" height="26" loading="lazy" />
      <span>Lelit Logistics LLC</span>
    </div>
    <nav class="footer__nav" aria-label="Legal">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/sms-consent">SMS Consent</a>
    </nav>
    <span class="footer__copy">© {year} · Glastonbury, CT · Independent Amazon DSP</span>
  </div>
</footer>

<style>
  .footer { padding-block: clamp(4rem, 9vw, 7rem) var(--s4); }
  .footer__cta {
    display: flex; align-items: center; justify-content: space-between;
    gap: var(--s4); flex-wrap: wrap;
    padding-bottom: clamp(var(--s6), 7vw, var(--s10));
    border-bottom: 1px solid rgba(245,245,247,.12);
    margin-bottom: var(--s4);
  }
  .footer__cta h2 { font-size: clamp(2rem, 5vw, 3.4rem); }
  .footer__bar {
    display: flex; align-items: center; gap: var(--s4); flex-wrap: wrap;
    font-size: 13.5px; color: rgba(245,245,247,.55);
  }
  .footer__brand { display: flex; align-items: center; gap: 10px; font-weight: 600; color: #F5F5F7; }
  .footer__brand img { border-radius: 6px; }
  .footer__nav { display: flex; gap: var(--s3); margin-left: auto; }
  .footer__nav a { text-decoration: none; transition: color .3s var(--ease); }
  .footer__nav a:hover { color: #F5F5F7; }
  .footer__copy { width: 100%; }
  @media (min-width: 720px) { .footer__copy { width: auto; margin-left: auto; } }
</style>
