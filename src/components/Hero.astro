---
---
<section class="hero" id="main">
  <div class="hero__mesh" aria-hidden="true"></div>

  <div class="wrap hero__inner">
    <span class="eyebrow" data-reveal style="--rd:0">
      Amazon Delivery Service Partner · Station DOB7 · Glastonbury, CT
    </span>

    <h1 class="hero__title">
      <span class="hero__line" data-reveal style="--rd:1">Every package.</span>
      <span class="hero__line" data-reveal style="--rd:2">Every door.</span>
      <span class="hero__line hero__line--accent" data-reveal style="--rd:3">On time.</span>
    </h1>

    <p class="hero__lead lead" data-reveal style="--rd:4">
      Last-mile delivery across central Connecticut — thousands of packages a
      day, moved by a crew that takes safety, precision, and people seriously.
    </p>

    <div class="hero__actions" data-reveal style="--rd:5">
      <a href="#careers" class="btn btn--dark">Drive with us <span class="arrow">↗</span></a>
      <a href="#contact" class="btn btn--ghost">Partner with us</a>
    </div>
  </div>

  <div class="wrap hero__stats" data-reveal style="--rd:6">
    <div><strong data-count="6000" data-suffix="+">0</strong><span>packages daily</span></div>
    <div class="hero__sep"></div>
    <div><strong data-count="20" data-suffix="+">0</strong><span>routes every day</span></div>
    <div class="hero__sep"></div>
    <div><strong data-count="35">0</strong><span>drivers on the road</span></div>
    <div class="hero__sep"></div>
    <div><strong data-count="99" data-suffix="%">0</strong><span>on-time target</span></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(5rem, 12vw, 9.5rem) clamp(3rem, 6vw, 5rem);
    text-align: center;
    overflow: hidden;
    background: var(--white);
  }
  .hero__mesh {
    position: absolute; inset: -20%;
    background:
      radial-gradient(38% 42% at 26% 24%, rgba(46,107,230,.07), transparent 70%),
      radial-gradient(34% 38% at 76% 18%, rgba(248,120,0,.05), transparent 70%),
      radial-gradient(50% 55% at 50% 90%, rgba(17,17,17,.03), transparent 70%);
    animation: meshDrift 24s ease-in-out infinite alternate;
    pointer-events: none;
  }
  @keyframes meshDrift {
    from { transform: translate3d(-1.5%, -1%, 0) scale(1); }
    to   { transform: translate3d(1.5%, 1.5%, 0) scale(1.04); }
  }
  .hero__inner { position: relative; }
  .hero__title {
    font-size: clamp(3rem, 9.4vw, 7rem);
    font-weight: 660;
    letter-spacing: -0.045em;
    line-height: 0.99;
    margin: var(--s2) 0 var(--s4);
  }
  .hero__line { display: block; }
  .hero__line--accent {
    background: linear-gradient(92deg, var(--accent), var(--accent-deep));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .hero__lead { max-width: 560px; margin: 0 auto var(--s5); }
  .hero__actions { display: flex; gap: var(--s2); justify-content: center; flex-wrap: wrap; }

  .hero__stats {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    gap: clamp(var(--s3), 4vw, var(--s8));
    margin-top: clamp(var(--s8), 9vw, var(--s12));
    padding-top: var(--s4);
    border-top: 1px solid var(--line);
    flex-wrap: wrap;
  }
  .hero__stats div:not(.hero__sep) { display: flex; flex-direction: column; gap: 2px; min-width: 96px; }
  .hero__stats strong {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 650; letter-spacing: -0.03em; color: var(--ink);
    font-variant-numeric: tabular-nums;
  }
  .hero__stats span { font-size: 13px; color: var(--gray); font-weight: 500; }
  .hero__sep { width: 1px; height: 40px; background: var(--line); }
  @media (max-width: 640px) { .hero__sep { display: none; } .hero__stats { gap: var(--s4); } }
</style>
