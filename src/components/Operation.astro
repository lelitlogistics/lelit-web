---
const steps = [
  { n: '01', title: 'Load out', body: 'Vans inspected, routes assigned, packages staged. Every morning starts with a checklist — not a guess. Gas card, keys, device: accounted for before the first mile.' },
  { n: '02', title: 'On the road', body: 'Standard parcel, oversize, and same-day routes across central Connecticut — dispatched, monitored, and supported end to end by a live dispatch team.' },
  { n: '03', title: 'At the door', body: 'Photo on delivery, right location, right handoff. The standard our name rides on happens in the last twenty feet — and we treat it that way.' },
  { n: '04', title: 'Return to station', body: 'Equipment checked back in, vans fueled and inspected, the day debriefed. Tomorrow starts tonight.' },
];
---
<section class="op" id="operation">
  <div class="wrap op__grid">
    <div class="op__sticky">
      <span class="eyebrow" data-reveal>The operation</span>
      <h2 data-reveal style="--rd:1">Built to run clean,<br />every single day.</h2>
      <p class="lead" data-reveal style="--rd:2">
        A delivery day is a system. Ours runs on discipline, live support,
        and tools we built ourselves.
      </p>
    </div>
    <div class="op__steps">
      {steps.map((s, i) => (
        <article class="op__step" data-reveal style={`--rd:${i}`}>
          <span class="op__n">{s.n}</span>
          <div>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .op { padding-block: clamp(5rem, 11vw, 9rem); background: var(--white); }
  .op__grid { display: grid; grid-template-columns: 5fr 6fr; gap: clamp(var(--s6), 6vw, var(--s16)); align-items: start; }
  .op__sticky { position: sticky; top: 120px; }
  .op__sticky h2 { margin-bottom: var(--s3); }
  .op__sticky .lead { max-width: 380px; }
  .op__steps { display: flex; flex-direction: column; }
  .op__step {
    display: flex; gap: var(--s3);
    padding: var(--s5) 0;
    border-top: 1px solid var(--line);
  }
  .op__step:last-child { border-bottom: 1px solid var(--line); }
  .op__n {
    font-size: 13px; font-weight: 650; color: var(--accent);
    font-variant-numeric: tabular-nums;
    padding-top: 5px; min-width: 32px;
  }
  .op__step h3 { margin-bottom: 8px; }
  .op__step p { font-size: 16px; line-height: 1.65; }
  @media (max-width: 860px) {
    .op__grid { grid-template-columns: 1fr; }
    .op__sticky { position: static; }
  }
</style>
