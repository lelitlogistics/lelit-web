---
const faqs = [
  { q: 'What do I need to apply as a driver?', a: 'A valid driver\u2019s license, a clean motor vehicle record, and the ability to pass a background check and drug screen. No CDL required — our vans are standard class.' },
  { q: 'How does training work?', a: 'Paid from day one. You\u2019ll complete Amazon\u2019s onboarding, then ride along with an experienced driver before running your own route. We don\u2019t send anyone out unprepared.' },
  { q: 'What\u2019s the schedule like?', a: 'Routes typically run 8\u201310 hours starting mid-morning. Full-time is 4\u20135 days a week including weekend days; part-time is 2\u20133. Schedules are published in advance.' },
  { q: 'Where do you operate?', a: 'Out of Amazon Station DOB7 in Glastonbury, delivering across central Connecticut.' },
  { q: 'How fast is the hiring process?', a: 'Most applicants go from application to first training day in about one to two weeks, depending on background check timing.' },
];
---
<section class="faq" id="faq">
  <div class="wrap faq__inner">
    <div class="faq__lead" data-reveal>
      <span class="eyebrow">Questions</span>
      <h2>Answers,<br />upfront.</h2>
    </div>
    <div class="faq__list">
      {faqs.map((f, i) => (
        <details class="faq__item" data-reveal style={`--rd:${i}`}>
          <summary>
            <span>{f.q}</span>
            <span class="faq__icon" aria-hidden="true"></span>
          </summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq { padding-block: clamp(4rem, 9vw, 7rem); border-top: 1px solid var(--line); background: var(--bg-2); }
  .faq__inner { display: grid; grid-template-columns: 4fr 7fr; gap: clamp(2rem, 6vw, 6rem); align-items: start; }
  .faq__lead { position: sticky; top: 110px; }
  .faq__item { border-top: 1px solid var(--line); }
  .faq__item:last-child { border-bottom: 1px solid var(--line); }
  .faq__item summary {
    display: flex; align-items: center; justify-content: space-between; gap: 1.5rem;
    padding: 1.35rem 0;
    font-family: var(--font-display);
    font-size: clamp(1.02rem, 1.4vw, 1.18rem); font-weight: 600;
    color: var(--fg); cursor: pointer; list-style: none;
    transition: color .3s ease;
  }
  .faq__item summary:hover { color: #fff; }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__icon { position: relative; width: 14px; height: 14px; flex-shrink: 0; }
  .faq__icon::before, .faq__icon::after {
    content: ''; position: absolute; inset: 0; margin: auto;
    background: var(--orange); transition: transform .4s cubic-bezier(.16,1,.3,1);
  }
  .faq__icon::before { width: 14px; height: 2px; }
  .faq__icon::after { width: 2px; height: 14px; }
  .faq__item[open] .faq__icon::after { transform: rotate(90deg); }
  .faq__item p { padding: 0 0 1.35rem; max-width: 60ch; color: var(--fg-soft); line-height: 1.65; }
  @media (max-width: 820px) {
    .faq__inner { grid-template-columns: 1fr; }
    .faq__lead { position: static; }
  }
</style>
