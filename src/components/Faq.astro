---
const faqs = [
  { q: 'What do I need to apply as a driver?', a: 'A valid driver\u2019s license, a clean motor vehicle record, and the ability to pass a background check and drug screen. No CDL required — our vans are standard class.' },
  { q: 'How does training work?', a: 'Paid from day one. You\u2019ll complete Amazon\u2019s onboarding, then ride along with an experienced driver before running your own route. We don\u2019t send anyone out unprepared.' },
  { q: 'What\u2019s the schedule like?', a: 'Routes typically run 8–10 hours starting mid-morning. Full-time is 4–5 days a week including weekend days; part-time is 2–3. Schedules are published in advance.' },
  { q: 'Where do you operate?', a: 'Out of Amazon Station DOB7 in Glastonbury, delivering across central Connecticut.' },
  { q: 'How fast is the hiring process?', a: 'Most applicants go from application to first training day in about one to two weeks, depending on background check timing.' },
];
---
<section class="faq" id="faq">
  <div class="wrap--tight">
    <span class="eyebrow" data-reveal>Questions</span>
    <h2 data-reveal style="--rd:1">Answers, upfront.</h2>
    <div class="faq__list">
      {faqs.map((f, i) => (
        <details class="faq__item" data-reveal style={`--rd:${i + 1}`}>
          <summary>
            <span>{f.q}</span>
            <span class="faq__icon" aria-hidden="true"></span>
          </summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq { padding-block: clamp(5rem, 11vw, 9rem); background: var(--white); }
  .faq h2 { margin-bottom: clamp(var(--s5), 4vw, var(--s8)); }
  .faq__item { border-top: 1px solid var(--line); }
  .faq__item:last-child { border-bottom: 1px solid var(--line); }
  .faq__item summary {
    display: flex; align-items: center; justify-content: space-between; gap: var(--s3);
    padding: var(--s3) 0;
    font-size: clamp(1.02rem, 1.5vw, 1.15rem);
    font-weight: 600; letter-spacing: -0.015em; color: var(--ink);
    cursor: pointer; list-style: none;
  }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__icon { position: relative; width: 14px; height: 14px; flex-shrink: 0; }
  .faq__icon::before, .faq__icon::after {
    content: ''; position: absolute; inset: 0; margin: auto;
    background: var(--gray); transition: transform .4s var(--ease-out);
  }
  .faq__icon::before { width: 14px; height: 1.5px; }
  .faq__icon::after { width: 1.5px; height: 14px; }
  .faq__item[open] .faq__icon::after { transform: rotate(90deg); }
  .faq__item p { padding: 0 0 var(--s3); max-width: 640px; font-size: 16px; line-height: 1.65; }
</style>
