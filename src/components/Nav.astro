---
const links = [
  { label: 'Company', href: '#company' },
  { label: 'Operation', href: '#operation' },
  { label: 'Technology', href: '#technology' },
  { label: 'Careers', href: '#careers' },
];
---
<header class="nav" id="top">
  <div class="wrap nav__inner">
    <a href="#top" class="brand" aria-label="Lelit Logistics — home">
      <img src="/logo-mark.png" alt="" width="30" height="30" loading="eager" />
      <span>Lelit&nbsp;Logistics</span>
    </a>
    <nav class="nav__links" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <a href="#contact" class="btn btn--dark nav__cta">Drive with us</a>
  </div>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(255,255,255,.72);
    backdrop-filter: blur(20px) saturate(1.6);
    -webkit-backdrop-filter: blur(20px) saturate(1.6);
    border-bottom: 1px solid var(--line);
  }
  .nav__inner { display: flex; align-items: center; gap: var(--s4); height: 68px; }
  .brand {
    display: flex; align-items: center; gap: 10px;
    font-weight: 650; letter-spacing: -0.02em; font-size: 16.5px;
    color: var(--ink); text-decoration: none;
  }
  .brand img { border-radius: 8px; }
  .nav__links { display: flex; gap: var(--s4); margin-left: auto; }
  .nav__links a {
    position: relative;
    font-size: 14.5px; font-weight: 520; color: var(--gray);
    text-decoration: none; padding: 6px 0;
    transition: color .3s var(--ease);
  }
  .nav__links a::after {
    content: ''; position: absolute; left: 0; right: 100%; bottom: 0;
    height: 1.5px; background: var(--ink);
    transition: right .4s var(--ease-out);
  }
  .nav__links a:hover { color: var(--ink); }
  .nav__links a:hover::after { right: 0; }
  .nav__cta { height: 42px; padding: 0 20px; font-size: 14px; }
  @media (max-width: 760px) {
    .nav__links { display: none; }
    .nav__cta { margin-left: auto; }
  }
</style>
