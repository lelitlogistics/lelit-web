---
const links = [
  { label: 'Company', href: '#company' },
  { label: 'Operation', href: '#operation' },
  { label: 'Drive with us', href: '#careers' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="nav" id="top">
  <div class="wrap nav__inner">
    <a href="#top" class="brand" aria-label="Lelit Logistics — home">
      <img src="/logo.png" alt="" class="brand__logo" width="34" height="34" />
      <span class="brand__name">Lelit<span class="brand__sub">Logistics</span></span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <a href="#careers" class="btn btn--orange nav__cta">
      Apply to drive <span class="arrow">↗</span>
    </a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: saturate(140%) blur(16px);
    -webkit-backdrop-filter: saturate(140%) blur(16px);
    border-bottom: 1px solid var(--line-soft);
  }
  .nav__inner { display: flex; align-items: center; gap: 1.5rem; height: 74px; }
  .brand {
    display: inline-flex; align-items: center; gap: 0.65rem;
    font-family: var(--font-display); font-weight: 700;
    font-size: 1.3rem; letter-spacing: -0.03em; margin-right: auto;
  }
  .brand__logo { object-fit: contain; }
  .brand__sub { color: var(--fg-faint); font-weight: 500; margin-left: 0.18em; }
  .nav__links { display: flex; gap: 1.9rem; font-size: 0.95rem; font-weight: 500; }
  .nav__links a { position: relative; color: var(--fg-soft); transition: color 0.25s var(--ease); }
  .nav__links a::after {
    content: ""; position: absolute; left: 0; bottom: -6px;
    width: 100%; height: 2px; background: var(--orange);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.35s var(--ease);
  }
  .nav__links a:hover { color: var(--fg); }
  .nav__links a:hover::after { transform: scaleX(1); }
  .nav__cta { padding: 0.65em 1.2em; font-size: 0.9rem; white-space: nowrap; }

  @media (max-width: 880px) {
    .nav__links { display: none; }
  }
  @media (max-width: 540px) {
    .brand { font-size: 1.1rem; }
    .brand__logo { width: 28px; height: 28px; }
    .nav__cta { padding: 0.55em 0.9em; font-size: 0.82rem; }
    .nav__cta .arrow { display: none; }
  }
  @media (max-width: 380px) {
    .brand__sub { display: none; }
  }
</style>
