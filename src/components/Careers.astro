---
const roles = [
  { n: '01', title: 'Full-Time Driver', tag: 'Now hiring', summary: 'The core of the operation. Run a route, treat the customer right, get home safe.' },
  { n: '02', title: 'Part-Time Driver', tag: 'Now hiring', summary: 'Fewer days, same standard. A great fit if you want a lighter, flexible week.' },
];
const perks = ['Paid training', 'Weekly pay', 'Real routes from day one', 'Growth into dispatch & ops', 'A crew that shows up for each other'];
---
<section class="careers" id="careers">
  <div class="wrap">
    <div class="careers__head">
      <span class="eyebrow" data-reveal>Careers</span>
      <h2 data-reveal style="--rd:1">Drive with us.</h2>
      <p class="lead" data-reveal style="--rd:2">
        New drivers ride before they run routes. Clear expectations, real
        support, and the tools to grow with us.
      </p>
    </div>

    <div class="careers__roles">
      {roles.map((r, i) => (
        <article class="role" data-reveal style={`--rd:${i + 2}`}>
          <div class="role__top">
            <span class="role__n">{r.n}</span>
            <span class="role__tag">{r.tag}</span>
          </div>
          <h3>{r.title}</h3>
          <p>{r.summary}</p>
          <a href="#contact" class="role__cta">Apply <span class="arrow">↗</span></a>
        </article>
      ))}
      <aside class="perks" data-reveal style="--rd:4">
        <h3>What you get</h3>
        <ul>
          {perks.map((p) => <li>{p}</li>)}
        </ul>
        <p class="perks__note">
          Questions first? <a href="mailto:hiring@lelitlogistics.com">hiring@lelitlogistics.com</a>
        </p>
      </aside>
    </div>
  </div>
</section>

<style>
  .careers { padding-block: clamp(5rem, 11vw, 9rem); background: var(--bg); border-top: 1px solid var(--line); }
  .careers__head { max-width: 560px; margin-bottom: clamp(var(--s6), 5vw, var(--s10)); }
  .careers__head h2 { margin-bottom: var(--s3); }
  .careers__roles { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--s2); }
  .role, .perks {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: var(--s4);
    box-shadow: var(--shadow-soft);
    transition: transform .5s var(--ease-out), box-shadow .5s var(--ease-out);
  }
  .role:hover { transform: translateY(-6px); box-shadow: var(--shadow-lift); }
  .role__top { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--s3); }
  .role__n { font-size: 13px; font-weight: 650; color: var(--gray); font-variant-numeric: tabular-nums; }
  .role__tag {
    font-size: 12px; font-weight: 640; letter-spacing: .04em;
    color: var(--accent);
    background: rgba(46,107,230,.08);
    border-radius: var(--r-full); padding: 5px 12px;
  }
  .role h3 { margin-bottom: 10px; }
  .role p { font-size: 15.5px; line-height: 1.6; margin-bottom: var(--s3); }
  .role__cta {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 14.5px; font-weight: 600; color: var(--ink);
    text-decoration: none;
  }
  .role__cta .arrow { transition: transform .35s var(--ease-out); font-size: 13px; }
  .role__cta:hover .arrow { transform: translate(2px, -2px); }
  .perks { background: var(--ink); border-color: var(--ink); color: #F5F5F7; }
  .perks h3 { color: #F5F5F7; margin-bottom: var(--s3); }
  .perks ul { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: var(--s3); }
  .perks li { font-size: 15px; color: rgba(245,245,247,.75); padding-left: 22px; position: relative; }
  .perks li::before { content: '—'; position: absolute; left: 0; color: rgba(245,245,247,.35); }
  .perks__note { font-size: 13.5px; color: rgba(245,245,247,.55); }
  .perks__note a { color: #F5F5F7; }
  @media (max-width: 900px) { .careers__roles { grid-template-columns: 1fr; } }
</style>
