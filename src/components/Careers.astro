---
const roles = [
  { n: '01', title: 'Full-Time Driver', tag: 'Now hiring', summary: 'The core of the operation. Run a route, treat the customer right, get home safe.',
    rows: [['Schedule','4 days / week'],['Hours','10 hrs per day'],['Weekend','One weekend day required'],['Pay','$22.25 / hr + OT']] },
  { n: '02', title: 'Part-Time Driver', tag: 'Now hiring', summary: 'Fewer days, same standard. A great fit if you want a lighter, flexible week.',
    rows: [['Schedule','3 days / week'],['Hours','10 hrs per day'],['Type','Part-time'],['Pay','$22.25 / hr']] },
];
const perks = [
  'Competitive hourly pay with weekly overtime',
  'Paid training before you ever run solo',
  'Fantastic Plus performance bonuses',
  'Gas card incentives for eligible roles',
  'Clear schedules — you know your week ahead',
  'A real path to grow as the company grows',
];
const benefits = [
  'Health, vision, and dental insurance',
  'Retirement program',
  'Referral program',
];
---

<section class="careers" id="careers">
  <div class="wrap">
    <div class="careers__head" data-reveal>
      <span class="eyebrow">Drive with us</span>
      <h2>Open roles</h2>
      <p>We hire for reliability and attitude. The route, the van, and the training — that part is on us.</p>
    </div>

    <div class="careers__grid">
      {roles.map((r, i) => (
        <article class="role" data-reveal style={`transition-delay:${i * 80}ms`}>
          <div class="role__top">
            <span class="role__n">{r.n}</span>
            <span class={`role__tag ${r.tag === 'Now hiring' ? 'role__tag--hot' : ''}`}>{r.tag}</span>
          </div>
          <h3>{r.title}</h3>
          <p class="role__summary">{r.summary}</p>
          <dl class="role__rows">
            {r.rows.map(([k, v]) => (<div><dt>{k}</dt><dd>{v}</dd></div>))}
          </dl>
          <a href="#contact" class="role__cta">Apply <span class="arrow">↗</span></a>
        </article>
      ))}
    </div>

    <div class="benefits" data-reveal>
      <h3>Benefits</h3>
      <div class="benefits__grid">
        {benefits.map((b) => (
          <div class="benefit"><span class="benefit__icon">+</span>{b}</div>
        ))}
      </div>
    </div>

    <div class="perks" data-reveal>
      <h3>Why drivers stay</h3>
      <ul>{perks.map((p) => <li>{p}</li>)}</ul>
      <p class="perks__note">Questions before you apply? Email <a href="mailto:hiring@lelitlogistics.com">hiring@lelitlogistics.com</a>.</p>
    </div>
  </div>
</section>

<style>
  .careers { padding-block: clamp(4.5rem, 10vw, 8rem); border-top: 1px solid var(--line); background: var(--bg-2); }
  .careers__head { max-width: 52ch; margin-bottom: clamp(2rem, 5vw, 3.5rem); }
  .careers__head h2 { font-size: clamp(2.4rem, 6vw, 4.2rem); margin: 1rem 0 0.8rem; }
  .careers__head p { color: var(--fg-soft); font-size: 1.1rem; }

  .careers__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.3rem; }

  .benefits {
    margin-top: 1.3rem; border: 1px solid var(--line); border-radius: var(--radius);
    padding: clamp(1.8rem, 4vw, 2.8rem);
    background:
      radial-gradient(circle at 0% 0%, rgba(248,120,0,0.1), transparent 42%),
      var(--surface);
  }
  .benefits h3 { font-size: 1.8rem; margin-bottom: 1.4rem; }
  .benefits__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .benefit {
    display: flex; align-items: center; gap: 0.7rem;
    border: 1px solid var(--line); border-radius: 12px;
    padding: 1rem 1.2rem; color: var(--fg); font-weight: 500;
    background: var(--bg-2);
  }
  .benefit__icon {
    flex-shrink: 0; width: 26px; height: 26px; border-radius: 8px;
    display: inline-flex; align-items: center; justify-content: center;
    background: rgba(32,136,248,0.16); color: var(--blue-soft);
    font-weight: 700; font-size: 1.1rem;
  }
  .role {
    display: flex; flex-direction: column;
    border: 1px solid var(--line); border-radius: var(--radius);
    padding: 1.7rem; background: var(--surface);
    transition: transform 0.45s var(--ease), box-shadow 0.45s var(--ease), border-color 0.45s var(--ease);
  }
  .role:hover {
    transform: translateY(-6px); border-color: var(--orange);
    box-shadow: 0 24px 50px -28px rgba(248,120,0,0.4);
  }
  .role__top { display: flex; justify-content: space-between; align-items: center; }
  .role__n { font-family: var(--font-display); color: var(--fg-faint); font-size: 1rem; letter-spacing: 0.1em; }
  .role__tag {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--blue-soft); background: rgba(32,136,248,0.14);
    padding: 0.35em 0.7em; border-radius: 100px;
  }
  .role__tag--hot { color: var(--orange-soft); background: rgba(248,120,0,0.14); }
  .role h3 { font-size: 1.65rem; margin: 1rem 0 0.5rem; }
  .role__summary { color: var(--fg-soft); font-size: 0.96rem; margin-bottom: 1.3rem; }
  .role__rows { display: flex; flex-direction: column; margin-top: auto; }
  .role__rows > div { display: flex; justify-content: space-between; gap: 1rem; padding: 0.6rem 0; border-top: 1px solid var(--line-soft); }
  .role__rows dt { color: var(--fg-faint); font-size: 0.82rem; letter-spacing: 0.03em; }
  .role__rows dd { font-weight: 600; font-size: 0.92rem; text-align: right; color: var(--fg); }
  .role__cta { display: inline-flex; align-items: center; gap: 0.5em; margin-top: 1.4rem; font-weight: 600; color: var(--orange-soft); transition: gap 0.3s var(--ease); }
  .role__cta .arrow { transition: transform 0.4s var(--ease); }
  .role:hover .role__cta .arrow { transform: translate(3px,-3px); }

  .perks {
    margin-top: 1.3rem; border: 1px solid var(--line); border-radius: var(--radius);
    padding: clamp(1.8rem, 4vw, 2.8rem);
    background:
      radial-gradient(circle at 100% 0%, rgba(32,136,248,0.1), transparent 42%),
      var(--surface);
  }
  .perks h3 { font-size: 1.8rem; margin-bottom: 1.4rem; }
  .perks ul { list-style: none; display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.9rem 2rem; }
  .perks li { position: relative; padding-left: 1.8rem; color: var(--fg-soft); }
  .perks li::before { content: "→"; position: absolute; left: 0; color: var(--orange); font-weight: 700; }
  .perks__note { margin-top: 1.6rem; font-size: 0.95rem; color: var(--fg-faint); }
  .perks__note a { color: var(--blue-soft); font-weight: 600; border-bottom: 1px solid currentColor; }

  @media (max-width: 880px) { .careers__grid { grid-template-columns: 1fr; } .benefits__grid { grid-template-columns: 1fr; } }
  @media (max-width: 620px) { .perks ul { grid-template-columns: 1fr; } }
</style>
