---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const updated = 'July 2, 2026';
---

<Base
  title="Privacy Policy — Lelit Logistics LLC"
  description="How Lelit Logistics LLC collects, uses, and protects the personal information of job applicants, employees, and delivery associates."
>
  <Nav />
  <main class="policy" id="main">
    <div class="wrap policy__inner">
      <span class="eyebrow">Legal</span>
      <h1>Privacy Policy</h1>
      <p class="policy__updated">Last updated: {updated}</p>

      <section>
        <p>
          This Privacy Policy describes how Lelit Logistics LLC ("we," "us," or
          "our") collects, uses, and protects the personal information of job
          applicants, employees, and delivery associates.
        </p>
      </section>

      <section>
        <h2>Information we collect</h2>
        <p>
          We collect personal information you voluntarily provide during the
          application and onboarding process, including:
        </p>
        <ul>
          <li>Full name, address, and contact information (phone number, email address)</li>
          <li>Driver's license information and driving record</li>
          <li>Employment history and references</li>
          <li>Background check and drug screening results, where permitted by law</li>
          <li>Any additional information you include in an application or message to us</li>
        </ul>
      </section>

      <section>
        <h2>How we use your information</h2>
        <ul>
          <li>To evaluate your application and qualifications for employment</li>
          <li>To communicate with you about your application, interviews, and onboarding</li>
          <li>To meet the requirements of our Delivery Service Partner agreement with Amazon</li>
          <li>To administer employment, payroll, scheduling, and performance programs</li>
          <li>To comply with applicable laws and regulations</li>
        </ul>
      </section>

      <section>
        <h2>SMS / text message notifications</h2>
        <p>
          Lelit Logistics LLC sends SMS notifications to job applicants and
          employees for: interview scheduling and confirmations, interview
          reminders, drug test instructions, onboarding updates,
          employment-related announcements, and weekly performance scorecard
          notifications.
        </p>
        <ul>
          <li>
            <strong>Consent:</strong> By providing your phone number during the
            application or onboarding process, you consent to receive SMS
            messages related to your application or employment. Consent is not
            a condition of employment.
          </li>
          <li>
            <strong>Opt-out:</strong> Reply <strong>STOP</strong> to any message
            to opt out. Reply <strong>HELP</strong> for help.
          </li>
          <li>
            <strong>Message frequency:</strong> Frequency varies by stage in
            your application or employment. Standard message and data rates may
            apply.
          </li>
          <li>
            Mobile information will not be shared with third parties or
            affiliates for marketing or promotional purposes.
          </li>
        </ul>
      </section>

      <section>
        <h2>How we share information</h2>
        <p>
          We do not sell, trade, or rent your personal information to third
          parties. We may share your information with Amazon as required by our
          DSP agreement, with background check providers, drug testing
          facilities, payroll and benefits providers, and as required by law.
        </p>
      </section>

      <section>
        <h2>Data security</h2>
        <p>
          We implement appropriate technical and organizational measures to
          protect your personal information against unauthorized access,
          alteration, disclosure, or destruction.
        </p>
      </section>

      <section>
        <h2>Your choices</h2>
        <p>
          You may request access to, correction of, or deletion of the personal
          information we hold about you, subject to legal and contractual
          obligations, by contacting us using the information below.
        </p>
      </section>

      <section>
        <h2>Contact us</h2>
        <p>Questions about this Privacy Policy? Contact us at:</p>
        <p class="policy__contact">
          Lelit Logistics LLC<br />
          35 National Drive<br />
          Glastonbury, CT 06033<br />
          <a href="mailto:HR@lelitlogistics.com">HR@lelitlogistics.com</a>
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .policy { padding-block: clamp(3.5rem, 8vw, 6rem); }
  .policy__inner { max-width: 72ch; }
  .policy h1 { font-size: clamp(2.4rem, 6vw, 4rem); margin: 1rem 0 0.4rem; }
  .policy__updated { color: var(--fg-faint); font-size: 0.9rem; margin-bottom: 2.5rem; }
  .policy section { margin-bottom: 2.2rem; }
  .policy h2 { font-size: 1.45rem; margin-bottom: 0.7rem; }
  .policy p { color: var(--fg-soft); margin-bottom: 0.8rem; }
  .policy ul { list-style: none; display: flex; flex-direction: column; gap: 0.55rem; margin-top: 0.4rem; }
  .policy li { position: relative; padding-left: 1.6rem; color: var(--fg-soft); }
  .policy li::before { content: "→"; position: absolute; left: 0; color: var(--orange); font-weight: 700; }
  .policy li strong { color: var(--fg); }
  .policy__contact { line-height: 1.7; }
  .policy a { color: var(--blue-soft); font-weight: 600; border-bottom: 1px solid currentColor; }
</style>
