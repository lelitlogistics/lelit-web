---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

// Google Analytics 4 — pega aquí el Measurement ID (formato G-XXXXXXXXXX)
// cuando crees la propiedad en analytics.google.com. Vacío = no carga nada.
const GA_ID = '';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Lelit Logistics — Amazon Delivery Service Partner | Glastonbury, CT',
  description = 'Lelit Logistics is an Amazon Delivery Service Partner based at Station DOB7 in Glastonbury, Connecticut. Reliable last-mile delivery and a place to build a driving career.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#080B11" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lelit Logistics" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Hanken+Grotesk:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />

    {GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_ID);
          // Astro view transitions: registrar cada navegación como pageview
          document.addEventListener('astro:page-load', () => {
            gtag('config', GA_ID, { page_path: window.location.pathname });
          });
        </script>
      </>
    )}
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>
    <slot />

    <script>
      // Scroll reveal — shared across page navigations
      const setup = () => {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
      };
      setup();
      document.addEventListener('astro:after-swap', setup);
    </script>

    <style>
      .skip {
        position: absolute;
        left: -999px;
        top: 0;
        background: var(--ink);
        color: var(--paper);
        padding: 0.8em 1.2em;
        z-index: 10000;
        border-radius: 0 0 12px 0;
      }
      .skip:focus { left: 0; }
    </style>
  </body>
</html>
